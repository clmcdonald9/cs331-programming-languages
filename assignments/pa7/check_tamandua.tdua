# initData - Initialize data arrays
func initData() {
    arrlen = 28;  # Length of arrays

    a[0] =  192;   a[1] =  166;   a[2] =  291;
    a[3] =  174;   a[4] =  861;   a[5] =  672;
    a[6] =  256;   a[7] =  911;   a[8] =  193;
