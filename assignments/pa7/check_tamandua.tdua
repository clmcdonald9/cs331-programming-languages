# Main Program
# Print a secret message -- somehow.

# Initialize data
initData();

# Print header
println("Secret message #5:");
println();

# Print the secret message (in a mysterious manner)
aa = 5;
bb = 9;
ii = 0;
while (ii < arrlen) {
    cc = (aa + bb) % 23;
    val = a[ii] - b[ii] + a[ii-1] + b[ii-1] + 2347 + cc;
    print(chr(32 + val % 94));
    aa = bb;
    bb = cc;
    ++ii;
}
println();


